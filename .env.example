# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Last.fm API credentials (required for genre resolution)
# Get yours at: https://www.last.fm/api/account/create
MUSICDL_LASTFM_API_KEY=your_lastfm_api_key_here
MUSICDL_LASTFM_API_SECRET=your_lastfm_api_secret_here

# MusicBrainz user agent (required by MusicBrainz ToS)
# Format: "AppName/Version contact@email.com"
MUSICDL_MB_USER_AGENT="musicdl/0.1 your@email.com"

# Soulseek credentials (required for downloads)
# Register free at: slsknet.org
MUSICDL_SLSK_USERNAME=your_soulseek_username
MUSICDL_SLSK_PASSWORD=your_soulseek_password
